{
  "name": "usman/new-wb",
  "description": "Simple PHP MVC Application running on Docker",
  "type": "project",
"require": {
    "php": ">=8.3",
    "ext-bcmath": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "doctrine/dbal": "^4.4",
    "doctrine/migrations": "^3.9",
    "doctrine/orm": "^3.6",
    "psr/container": "^2.0",
    "symfony/cache": "^7.4",
    "symfony/mailer": "^7.4",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }       
  },
  "autoload-dev": {
    "psr-4": {
        "Tests\\": "tests/"
     }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "symfony/var-dumper": "^7.0"
  },
  "scripts": {
    "post-autoload-dump": [
      "echo Autoload generated successfully"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
